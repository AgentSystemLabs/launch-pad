{
  "name": "@agentsystemlabs/launch-pad-dashboard",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Local web dashboard for Launch Pad — manage clusters, nodes, projects, deploys, env, logs, and CPU/memory, all by driving the launch-pad CLI.",
  "scripts": {
    "dev": "run-p server tailwind",
    "server": "bun --watch src/index.tsx",
    "start": "bun src/index.tsx",
    "tailwind": "tailwindcss -i src/styles.css -o dist/styles.css --watch",
    "build:tailwind": "tailwindcss -i src/styles.css -o dist/styles.css",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@agentsystemlabs/launch-pad-shared": "file:../shared",
    "@orbital-js/station": "file:../../../orbital-js/packages/station",
    "daisyui": "^4.12.10",
    "hono": "^4.5.0",
    "npm-run-all": "^4.1.5",
    "smol-toml": "^1.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/bun": "latest",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.0.0"
  }
}
