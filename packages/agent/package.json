{
  "name": "@agentsystemlabs/launch-pad-agent",
  "version": "0.0.0",
  "description": "The launch-pad node agent — reconciles Docker to the desired state in S3.",
  "type": "module",
  "main": "./dist/index.cjs",
  "exports": {
    ".": "./dist/index.cjs"
  },
  "bin": {
    "launch-pad-agent": "./dist/index.cjs"
  },
  "files": ["dist"],
  "scripts": {
    "build": "pnpm --filter @agentsystemlabs/launch-pad-shared build && tsup",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@agentsystemlabs/launch-pad-shared": "workspace:*",
    "@aws-sdk/client-ecr": "^3.726.0",
    "@aws-sdk/client-s3": "^3.726.0",
    "execa": "^9.5.2",
    "zod": "^3.24.1"
  }
}
