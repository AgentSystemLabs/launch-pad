{
  "name": "@agentsystemlabs/launch-pad",
  "version": "0.3.0",
  "description": "Deploy your apps to your own AWS infrastructure — one command.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AgentSystemLabs/launch-pad.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/AgentSystemLabs/launch-pad#readme",
  "bugs": "https://github.com/AgentSystemLabs/launch-pad/issues",
  "type": "module",
  "bin": {
    "launchpad": "./dist/index.js",
    "launch-pad": "./dist/index.js",
    "lpd": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prelink": "pnpm --filter @agentsystemlabs/launch-pad-shared build && tsup && pnpm run build:css",
    "build": "pnpm --filter @agentsystemlabs/launch-pad-shared build && tsup && pnpm run build:css",
    "build:css": "tailwindcss -c tailwind.config.cjs -i src/dashboard/styles.css -o dist/dashboard.css --minify",
    "prepublishOnly": "pnpm run build",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@aws-sdk/client-cloudwatch-logs": "^3.726.0",
    "@aws-sdk/client-codebuild": "^3.1065.0",
    "@aws-sdk/client-ec2": "^3.726.0",
    "@aws-sdk/client-ecr": "^3.726.0",
    "@aws-sdk/client-iam": "^3.726.0",
    "@aws-sdk/client-s3": "^3.726.0",
    "@aws-sdk/client-sns": "^3.726.0",
    "@aws-sdk/client-sqs": "^3.726.0",
    "@aws-sdk/client-ssm": "^3.726.0",
    "@aws-sdk/client-sts": "^3.726.0",
    "@aws-sdk/s3-request-presigner": "^3.726.0",
    "commander": "^12.1.0",
    "execa": "^9.5.2",
    "hono": "^4.6.14",
    "ora": "^8.1.1",
    "picocolors": "^1.1.1",
    "smol-toml": "^1.3.1",
    "tar": "^7.5.16",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@agentsystemlabs/launch-pad-agent": "workspace:*",
    "@agentsystemlabs/launch-pad-shared": "workspace:*",
    "@playwright/test": "^1.49.0",
    "daisyui": "^4.12.10",
    "tailwindcss": "^3.4.6"
  }
}
