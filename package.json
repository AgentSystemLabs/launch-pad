{
  "name": "launch-pad-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r --parallel run dev",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "e2e": "pnpm -r run build && pnpm --filter @agentsystemlabs/launch-pad-e2e run e2e",
    "clean": "pnpm -r exec rm -rf dist .turbo *.tsbuildinfo"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
