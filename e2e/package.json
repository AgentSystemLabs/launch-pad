{
  "name": "@agentsystemlabs/launch-pad-e2e",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Real-AWS end-to-end test for launch-pad (gated, on-demand — not part of `pnpm test`).",
  "scripts": {
    "e2e": "tsx src/run.ts",
    "e2e:scale": "tsx src/scale.ts",
    "e2e:undeploy": "tsx src/undeploy.ts",
    "e2e:deploy-image": "tsx src/deploy-image.ts",
    "e2e:rollback": "tsx src/rollback.ts",
    "e2e:dns": "tsx src/dns-setup.ts",
    "e2e:empty-cluster": "tsx src/empty-cluster.ts",
    "e2e:auto-add": "tsx src/auto-add-node.ts",
    "e2e:setup": "tsx src/setup.ts",
    "e2e:backup": "tsx src/backup.ts",
    "e2e:cost": "tsx src/cost.ts",
    "e2e:idle": "tsx src/idle.ts",
    "e2e:history": "tsx src/history.ts",
    "e2e:node-iam": "tsx src/node-iam.ts",
    "e2e:operator-iam": "tsx src/operator-iam.ts",
    "e2e:rebalance": "tsx src/rebalance.ts",
    "typecheck": "tsc --noEmit",
    "test": "echo \"e2e is a live AWS harness — run \\`pnpm e2e\\` (see README)\" && exit 0"
  },
  "dependencies": {
    "@aws-sdk/client-route-53": "^3.726.0",
    "@aws-sdk/client-s3": "^3.726.0",
    "execa": "^9.5.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
